<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PDFlow | Elegant PDF Tools</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-[#f3f3f3] text-gray-800">

    <!-- Header -->
    <nav class="bg-white py-4 px-10 flex justify-between items-center shadow-sm fixed w-full z-50">
        <h1 class="text-3xl font-black text-red-600 tracking-tighter">PDF<span class="text-slate-800">LOW</span></h1>
        <div class="hidden md:flex space-x-6 font-bold uppercase text-xs tracking-widest text-gray-500">
            <a href="#" class="hover:text-red-600 transition">Merge</a>
            <a href="#" class="hover:text-red-600 transition">Split</a>
            <a href="#" class="hover:text-red-600 transition">Compress</a>
        </div>
    </nav>

    <!-- Hero Section -->
    <header class="pt-40 pb-20 px-4 text-center">
        <h2 data-aos="fade-down" class="text-5xl md:text-6xl font-extrabold mb-4 text-slate-900">Make PDF easy.</h2>
        <p data-aos="fade-up" class="text-xl text-gray-500 max-w-xl mx-auto">Modern tools for all your PDF requirements. Professional, fast, and secure.</p>
    </header>

    <!-- Tools Grid -->
    <section class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-6 px-6 pb-20">
        <div onclick="openModal('merge')" data-aos="zoom-in" class="bg-white p-8 rounded-2xl shadow-md hover:shadow-2xl transition-all cursor-pointer group">
            <i class="fa-solid fa-layer-group text-4xl text-red-500 mb-4 group-hover:scale-110 transition-transform"></i>
            <h3 class="text-xl font-bold">Merge PDF</h3>
            <p class="text-gray-400 mt-2 text-sm">Combine several PDFs into one easily.</p>
        </div>

        <div onclick="openModal('rotate')" data-aos="zoom-in" data-aos-delay="100" class="bg-white p-8 rounded-2xl shadow-md hover:shadow-2xl transition-all cursor-pointer group">
            <i class="fa-solid fa-arrows-rotate text-4xl text-blue-500 mb-4 group-hover:rotate-180 transition-transform duration-500"></i>
            <h3 class="text-xl font-bold">Rotate PDF</h3>
            <p class="text-gray-400 mt-2 text-sm">Turn your PDFs however you like.</p>
        </div>

        <div data-aos="zoom-in" data-aos-delay="200" class="bg-white p-8 rounded-2xl shadow-md hover:shadow-2xl transition-all cursor-pointer group">
            <i class="fa-solid fa-file-pdf text-4xl text-green-500 mb-4"></i>
            <h3 class="text-xl font-bold">Word to PDF</h3>
            <p class="text-gray-400 mt-2 text-sm">Convert Word docs with precision.</p>
        </div>
    </section>

    <!-- Hidden Upload Modal -->
    <div id="modal" class="fixed inset-0 bg-black/70 backdrop-blur-sm z-[60] hidden flex items-center justify-center p-6">
        <div class="bg-white w-full max-w-lg rounded-3xl p-10 relative">
            <button onclick="closeModal()" class="absolute top-5 right-5 text-gray-400"><i class="fa-solid fa-xmark text-2xl"></i></button>
            <h2 id="tool-name" class="text-3xl font-bold text-center mb-8 italic uppercase tracking-tighter"></h2>
            
            <form id="upload-form">
                <div id="drop-area" class="border-4 border-dashed border-gray-100 rounded-3xl py-20 flex flex-col items-center justify-center hover:bg-red-50 transition-colors cursor-pointer">
                    <i class="fa-solid fa-cloud-arrow-up text-5xl text-red-500 mb-4 animate-bounce"></i>
                    <p class="font-medium">Drop your PDF files here</p>
                    <input type="file" id="fileInput" class="hidden" multiple accept="application/pdf">
                    <button type="button" onclick="document.getElementById('fileInput').click()" class="mt-4 bg-red-600 text-white px-8 py-3 rounded-full font-bold shadow-lg shadow-red-200">Select Files</button>
                </div>
                
                <!-- Loading Animation -->
                <div id="loading" class="hidden text-center py-10">
                    <div class="w-12 h-12 border-4 border-red-500 border-t-transparent rounded-full animate-spin mx-auto mb-4"></div>
                    <p class="font-bold text-red-600 uppercase tracking-widest text-xs">Processing Your Files...</p>
                </div>

                <button id="process-btn" type="submit" class="w-full mt-6 bg-slate-900 text-white py-4 rounded-xl font-bold text-lg hidden">DOWNLOAD PROCESSED FILE</button>
            </form>
        </div>
    </div>

    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="/js/script.js"></script>
</body>
</html>
